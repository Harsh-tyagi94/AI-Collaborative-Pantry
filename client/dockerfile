# ══════════════════════════════════════════════════════
# Client Dockerfile — Production
# Stage 1: TypeScript compile + Vite build → dist/
# Stage 2: Serve dist/ with nginx (no Node needed)
# ══════════════════════════════════════════════════════

# ── Stage 1: Build ─────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./

# Install ALL deps (TypeScript, Vite etc. are devDeps but needed for build)
RUN npm ci

COPY . .

# Vite bakes these into the JS bundle at build time
# They MUST be passed here — runtime env vars don't work in the browser
ARG VITE_BACKEND_URL
ARG VITE_WEBSOCKET_URL
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL
ENV VITE_WEBSOCKET_URL=$VITE_WEBSOCKET_URL

# Mirrors your "build" script: tsc -b && vite build
RUN npm run build
# Output is in /app/dist

# ── Stage 2: Serve ─────────────────────────────────────
FROM nginx:1.25-alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Our config: SPA routing + proxy to backend
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy the built React app
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]