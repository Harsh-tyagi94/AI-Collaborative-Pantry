# ══════════════════════════════════════════════════════
# Server Dockerfile — Production
# Plain JavaScript (ESM), no TypeScript compile step
# ══════════════════════════════════════════════════════
FROM node:20-alpine

WORKDIR /app

# Copy manifests first — Docker caches this layer
# Packages only re-download when package.json changes
COPY package*.json ./

# Install production deps only (no nodemon needed in prod)
RUN npm ci --omit=dev

# Copy all source files
COPY . .

EXPOSE 8000

# Health check so docker-compose knows when the server is ready
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8000/health || exit 1

# Start directly with node — no nodemon in production
CMD ["node", "-r", "dotenv/config", "--experimental-json-modules", "src/index.js"]