# 1. Use Node.js version 22
FROM node:22-alpine

# 2. Set the working directory inside the container
WORKDIR /usr/src/app

# 3. Copy package files and install dependencies
COPY package*.json ./
RUN npm install

# 4. Copy the rest of the server code
COPY . .

# 5. Expose the port our app runs on
ENV PORT=5173
EXPOSE 5000

# 6. Start the app (we'll use nodemon for development later)
CMD ["npm", "start"]